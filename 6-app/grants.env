# Downstream resources the app's service principal must reach.
# deploy.sh sources this file and grant_app_sp.sh applies the grants.
# Fill these in after steps 3 (Genie spaces) and 5 (supervisor + KA endpoints).

# Serving endpoints to grant CAN_QUERY (supervisor + every Knowledge Assistant it calls).
# The supervisor endpoint is also read from app.yaml's SUPERVISOR_ENDPOINT; list KA endpoints here.
ENDPOINTS=""   # fill after Step 5: "mas-<id>-endpoint ka-<id>-endpoint"

# Genie space IDs from step 3 (CAN_RUN).
GENIE_SPACE_IDS=""   # fill after Step 3 (space ids, space-separated)

# SQL warehouse the Genie spaces run on (CAN_USE).
WAREHOUSE_ID="d6a9e269c6d0868b"

# Unity Catalog target (catalog + schema get USE/SELECT/READ_VOLUME/EXECUTE;
# SELECT at schema level cascades to every table + metric view).
CATALOG="serverless_stable_umpuol_catalog"
SCHEMA="kailyn_klaassen"
